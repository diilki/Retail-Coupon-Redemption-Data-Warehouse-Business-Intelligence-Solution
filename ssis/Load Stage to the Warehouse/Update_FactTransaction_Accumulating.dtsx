      DTS:DTSID="{1A7D0A1F-A3C8-40DA-BFEC-33CCB4D0769E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update FactTransaction Completion"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{7B0FB7A5-7B20-4197-B21D-9B07D69A588E}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET&#xA;    f.accm_txn_complete_time = s.accm_txn_complete_time,&#xA;    f.txn_process_time_hours =&#xA;        DATEDIFF(MINUTE, f.accm_txn_create_time, s.accm_txn_complete_time) / 60.0,&#xA;    f.ModifiedDate = GETDATE()&#xA;FROM Coupon_DW.dbo.FactTransaction f&#xA;INNER JOIN Coupon_Staging.dbo.Stg_FactTransactionCompletion s&#xA;    ON f.TransactionAlternateID = s.txn_id&#xA;WHERE s.accm_txn_complete_time IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
